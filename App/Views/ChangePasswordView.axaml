<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
             x:Class="App.Views.ChangePasswordView"
             x:DataType="vm:ChangePasswordViewModel">

    <Design.DataContext>
        <vm:ChangePasswordViewModel/>
    </Design.DataContext>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" Width="320" Margin="20">
        <TextBlock Text="Change Password" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Text="You must change your password before continuing." TextWrapping="Wrap" />

        <TextBlock Text="New Password" />
        <TextBox Text="{Binding Password1}" PasswordChar="*" PlaceholderText="Enter new password" />

        <TextBlock Text="Confirm Password" />
        <TextBox Text="{Binding Password2}" PasswordChar="*" PlaceholderText="Repeat new password" />

        <Button Command="{Binding ChangePasswordCommand}" Content="Change Password" HorizontalAlignment="Center" />

        <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Foreground="Red" />
    </StackPanel>

</UserControl>